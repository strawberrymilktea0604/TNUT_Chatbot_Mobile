# ===============================================================
#         ENVIRONMENT VARIABLES FOR AUTHENTICATION SERVICE
# ===============================================================

# ---------------------------------------------------------------
# MONGODB DATABASE CONNECTION
# Connection string for your MongoDB database.
# ---------------------------------------------------------------
# For a local instance
MONGODB_URL=mongodb://localhost:27017
# For a cloud instance (e.g., MongoDB Atlas)
# MONGODB_URL=mongodb+srv://<username>:<password>@<cluster-url>/<database_name>?retryWrites=true&w=majority

# The name of the database to use within your MongoDB instance.
DATABASE_NAME=aichatbox

# ---------------------------------------------------------------
# JSON WEB TOKEN (JWT)
# Used for securing API endpoints by creating and verifying tokens.
# ---------------------------------------------------------------
# A strong, unique secret key for signing JWTs.
# You can generate one using: openssl rand -hex 32
JWT_SECRET_KEY=your_super_secret_jwt_key_here
# How long an access token is valid (in minutes).
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
# How long a refresh token is valid (in days).
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# ---------------------------------------------------------------
# EMAIL SERVER (SMTP)
# Used for sending verification and password reset emails.
# Example uses Gmail's SMTP server.
# ---------------------------------------------------------------
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your_gmail_app_password # Use an App Password, not your regular password
MAIL_FROM=your-email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_STARTTLS=True
MAIL_SSL_TLS=False

# ---------------------------------------------------------------
# GOOGLE OAUTH 2.0
# Used for "Sign in with Google" functionality.
# Get these from your Google Cloud Console.
# ---------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ---------------------------------------------------------------
# CHATBOT SERVICE URL
# The address where the authentication service can reach the chatbot service.
# ---------------------------------------------------------------
CHATBOT_SERVICE_URL=http://localhost:5000