<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".MyApplication"
        android:usesCleartextTraffic="true"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.TNUTChatBoxApp"
        tools:targetApi="31">
        
        <!-- Splash Activity -->
        <activity
            android:name=".SplashActivity"
            android:exported="false">
        </activity>
        
        <!-- Welcome Activity -->
        <activity
            android:name=".WelcomeActivity"
            android:exported="true"
            android:theme="@style/Theme.TNUTChatBoxApp.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        
        <!-- Auth Activities -->
        <activity
            android:name=".auth.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.TNUTChatBoxApp.NoActionBar" />
            
        <activity
            android:name=".auth.RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.TNUTChatBoxApp.NoActionBar" />
            
        <activity
            android:name=".auth.GoogleRegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.TNUTChatBoxApp.NoActionBar" />
            
        <activity
            android:name=".auth.ForgotPasswordActivity"
            android:exported="false"
            android:theme="@style/Theme.TNUTChatBoxApp.NoActionBar" />
            
        <activity
            android:name=".auth.ResetPasswordActivity"
            android:exported="false"
            android:theme="@style/Theme.TNUTChatBoxApp.NoActionBar" />
        
        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.TNUTChatBoxApp.NoActionBar">
        </activity>
        
        <!-- Chat History Activity -->
        <activity
            android:name=".ChatHistoryActivity"
            android:exported="false"
            android:theme="@style/Theme.TNUTChatBoxApp" />
        
        <!-- Account Management Activities -->
        <activity
            android:name=".account.ChangePasswordActivity"
            android:exported="false"
            android:theme="@style/Theme.TNUTChatBoxApp" />
            
        <activity
            android:name=".account.ChangeEmailActivity"
            android:exported="false"
            android:theme="@style/Theme.TNUTChatBoxApp" />
            
        <activity
            android:name=".account.ChangeEmailVerificationActivity"
            android:exported="false"
            android:theme="@style/Theme.TNUTChatBoxApp" />
        
        <activity
            android:name=".ErrorActivity"
            android:exported="false"
            android:theme="@style/Theme.TNUTChatBoxApp.NoActionBar" />
    </application>

</manifest>
