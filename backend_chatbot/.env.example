# ===============================================================
#         ENVIRONMENT VARIABLES FOR CHATBOT SERVICE
# ===============================================================

# ---------------------------------------------------------------
# QDRANT VECTOR DATABASE
# Used for storing and searching vector embeddings for the RAG system.
# ---------------------------------------------------------------
# URL for your Qdrant instance. Can be local or a cloud deployment.
QDRANT_URL=http://localhost:6333
# API Key for Qdrant Cloud (if you are using it). Leave blank for local instances.
QDRANT_API_KEY=your_qdrant_api_key_if_any

# ---------------------------------------------------------------
# GOOGLE GEMINI API
# Used for the generative language model.
# ---------------------------------------------------------------
# Your Google Gemini API Key.
# Get one from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ---------------------------------------------------------------
# HUGGING FACE HUB
# Used for downloading the language models (LLM, embedding, reranker).
# ---------------------------------------------------------------
# Your Hugging Face API Key for accessing models.
# Get one from https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here